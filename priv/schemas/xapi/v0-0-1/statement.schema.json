        "extensions": {
          "$ref": "#/$defs/videoContextExtensionsBase"
        }
      },
      "required": [
        "contextActivities",
        "extensions"
      ],
      "additionalProperties": false
    },
    "activityAttemptEvaluated": {
      "type": "object",
      "properties": {
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "verb": {
          "type": "object",
          "properties": {
            "id": {
              "const": "http://adlnet.gov/expapi/verbs/completed"
            },
            "display": {
              "$ref": "#/$defs/langString"
            }
          },
          "required": [
            "id",
            "display"
          ],
          "additionalProperties": false
        },
        "object": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "definition": {
              "type": "object",
              "properties": {
                "name": {
                  "$ref": "#/$defs/langString"
                },
                "type": {
                  "const": "http://oli.cmu.edu/extensions/activity_attempt"
                }
              },
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false
            },
            "objectType": {
              "const": "Activity"
            }
          },
          "required": [
            "id",
            "definition",
            "objectType"
          ],
          "additionalProperties": false
        },
        "result": {
          "type": "object",
          "properties": {
            "score": {
              "$ref": "#/$defs/score"
            },
            "completion": {
              "const": true
            },
            "success": {
              "const": true
            }
          },
          "required": [
            "score",
            "completion",
            "success"
          ],
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "properties": {
            "extensions": {
              "allOf": [
                {
                  "$ref": "#/$defs/attemptContextExtensionsBase"
                },
                {
                  "type": "object",
                  "properties": {
                    "http://oli.cmu.edu/extensions/activity_attempt_number": {
                      "type": "integer"
                    },
                    "http://oli.cmu.edu/extensions/activity_attempt_guid": {
                      "type": "string"
                    },
                    "http://oli.cmu.edu/extensions/activity_id": {
                      "type": "integer"
                    },
                    "http://oli.cmu.edu/extensions/activity_revision_id": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "http://oli.cmu.edu/extensions/activity_attempt_number",
                    "http://oli.cmu.edu/extensions/activity_attempt_guid",
                    "http://oli.cmu.edu/extensions/activity_id",
                    "http://oli.cmu.edu/extensions/activity_revision_id"
                  ]
                }
              ]
            }
          },
          "required": [
            "extensions"
          ],
          "additionalProperties": false
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": [
        "actor",
        "verb",
        "object",
        "result",
        "context",
        "timestamp"
      ],
      "additionalProperties": false
    },
