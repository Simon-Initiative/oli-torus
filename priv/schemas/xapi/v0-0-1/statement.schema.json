{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.oli.cmu.edu/xapi/v0-0-1/statement.schema.json",
  "title": "OLI xAPI Statement v0.0.1",
  "description": "Reference schema for xAPI statements emitted by Torus analytics producers. Statements are top-level xAPI objects and are not wrapped under a `statement` property.",
  "anyOf": [
    {
      "$ref": "#/$defs/activityAttemptEvaluated"
    },
    {
      "$ref": "#/$defs/pageAttemptEvaluated"
    },
    {
      "$ref": "#/$defs/partAttemptEvaluated"
    },
    {
      "$ref": "#/$defs/pageViewed"
    },
    {
      "$ref": "#/$defs/tutorMessage"
    },
    {
      "$ref": "#/$defs/videoPlayed"
    },
    {
      "$ref": "#/$defs/videoPaused"
    },
    {
      "$ref": "#/$defs/videoSeeked"
    },
    {
      "$ref": "#/$defs/videoCompleted"
    }
  ],
  "$defs": {
    "jsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "langString": {
      "type": "object",
      "properties": {
        "en-US": {
          "type": "string"
        }
      },
      "required": [
        "en-US"
      ],
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "properties": {
        "account": {
          "type": "object",
          "properties": {
            "homePage": {
              "type": "string"
            },
            "name": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            }
          },
          "required": [
            "homePage",
            "name"
          ],
          "additionalProperties": false
        },
        "objectType": {
          "const": "Agent"
        }
      },
      "required": [
        "account",
        "objectType"
      ],
      "additionalProperties": false
    },
    "score": {
      "type": "object",
      "properties": {
        "scaled": {
          "type": "number"
        },
        "raw": {
          "type": "number"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "required": [
        "scaled",
        "raw",
        "min",
        "max"
      ],
      "additionalProperties": false
    },
    "attemptContextExtensionsBase": {
      "type": "object",
      "properties": {
        "http://oli.cmu.edu/extensions/section_id": {
          "type": "integer"
        },
        "http://oli.cmu.edu/extensions/project_id": {
          "type": "integer"
        },
        "http://oli.cmu.edu/extensions/publication_id": {
          "type": "integer"
        },
        "http://oli.cmu.edu/extensions/page_id": {
          "type": "integer"
        },
        "http://oli.cmu.edu/extensions/page_attempt_guid": {
          "type": "string"
        },
        "http://oli.cmu.edu/extensions/page_attempt_number": {
          "type": "integer"
        }
      },
      "required": [
        "http://oli.cmu.edu/extensions/section_id",
        "http://oli.cmu.edu/extensions/project_id",
        "http://oli.cmu.edu/extensions/publication_id",
        "http://oli.cmu.edu/extensions/page_id"
      ],
      "additionalProperties": true
    },
    "attemptContext": {
      "type": "object",
      "properties": {
        "extensions": {
          "$ref": "#/$defs/attemptContextExtensionsBase"
        }
      },
      "required": [
        "extensions"
      ],
      "additionalProperties": false
    },
    "videoContextActivities": {
      "type": "object",
      "properties": {
        "category": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "const": "https://w3id.org/xapi/video"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": [
        "category"
      ],
      "additionalProperties": false
    },
