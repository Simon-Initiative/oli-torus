{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manual Testing Test Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "test_id",
    "status",
    "started_at",
    "completed_at",
    "duration_seconds",
    "steps",
    "assertions",
    "agent_notes",
    "confidence"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "test_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "error"]
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string",
      "minLength": 1
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "base_url": {
      "type": "string",
      "minLength": 1
    },
    "case_path": {
      "type": "string",
      "minLength": 1
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_kind": {
      "type": "string",
      "enum": [
        "validation_failed",
        "blocked",
        "assertion_failed",
        "execution_error"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "instruction", "status"],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "instruction": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assertion_id", "description", "status"],
        "properties": {
          "assertion_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "unverified"]
          },
          "observed": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "agent_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "upload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "succeeded", "failed"]
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "uploaded_at": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
