{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manual Testing Test Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "tests"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base_url_label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
